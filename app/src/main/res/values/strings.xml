        Toggle the usage of dynamic colors. This feature is available only on <b>Android 12</b> or higher.
    </string>

    <!--Group General-->
    <string name="pref_header_general">@string/general</string>
    <string name="pref_enable_trash_can">Enable trash can</string>
    <string name="pref_enable_trash_can_summery">
        <b><i>Only available on Android 11 and above</i></b>, when enabled, deleted tracks are moved
