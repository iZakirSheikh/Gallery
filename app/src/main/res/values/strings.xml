    </string>
    <string name="pref_blacklisted_files">Blacklist</string>
    <string name="pref_blacklisted_files_summery">Files from the <b><i>blacklist folders</i></b> will be hidden from your library.</string>

    <!--Group title-->
    <string name="pref_header_feedback">@string/feedback</string>
    <string name="pref_feedback">@string/feedback</string>
    <string name="pref_feedback_summery">Have feedback? We\'d love to hear it, but please don\'t share sensitive information.</string>

    <string name="pref_rate_us">Rate Us</string>
