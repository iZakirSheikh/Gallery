        Thanks for your support \nTap to rate.
    </string>

    <string name="pref_spread_the_word">Spread the word</string>
    <string name="pref_spread_the_word_summery">
       We appreciate your support for the app. If you love it, please share it with your friends,
        family and WhatsApp groups. Remember, sharing is caring!
    </string>

    <string name="pref_header_about_us">About Us</string>
